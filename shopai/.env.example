# ── ShopAI Optional Environment Variables ──────────────────────────────────
# The project runs perfectly OUT OF THE BOX without any of these.
# They are only needed if you want REAL payments / SMS / AI chatbot fallback.
# To use: copy this file to ".env" and fill in real values, OR just set them
# as OS environment variables before running the server.

# ── Razorpay (https://dashboard.razorpay.com) — for real UPI/card payments ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# ── Stripe (https://dashboard.stripe.com) — for international cards ────────
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ── Twilio SMS (https://www.twilio.com) — for real SMS OTP ─────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── OpenAI (https://platform.openai.com) — fallback for AI chatbot ─────────
# Without this, the chatbot still works great using its built-in rule-based
# engine (covers orders, shipping, returns, payments, products, etc.)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
